# Devin BYOK Bridge — 环境变量模板
# 复制为 .env 后填写；.env 已被 .gitignore 排除，切勿提交到 Git。
# 通常由扩展侧栏「一键启动」自动写入，本文件仅供手动参考。

# ─── BYOK #1 ───
BYOK1_ANTHROPIC_API_HOST=
BYOK1_ANTHROPIC_API_KEY=
BYOK1_ANTHROPIC_API_PATH=/v1/messages
BYOK1_OPENAI_API_HOST=
BYOK1_OPENAI_API_KEY=
BYOK1_OPENAI_API_PATH=/v1/responses
BYOK1_OPENAI_SERVICE_TIER=
BYOK1_MODEL=
BYOK1_THINKING_EFFORT=

# ─── BYOK #2 ───
BYOK2_ANTHROPIC_API_HOST=
BYOK2_ANTHROPIC_API_KEY=
BYOK2_ANTHROPIC_API_PATH=/v1/messages
BYOK2_OPENAI_API_HOST=
BYOK2_OPENAI_API_KEY=
BYOK2_OPENAI_API_PATH=/v1/responses
BYOK2_OPENAI_SERVICE_TIER=
BYOK2_MODEL=
BYOK2_THINKING_EFFORT=

# ─── 兼容 / 补全（镜像 BYOK #1）───
ANTHROPIC_API_HOST=
ANTHROPIC_API_KEY=
ANTHROPIC_API_PATH=/v1/messages
OPENAI_API_HOST=
OPENAI_API_KEY=
OPENAI_API_PATH=/v1/responses
OPENAI_SERVICE_TIER=
DEFAULT_MODEL=
OPENAI_REASONING_EFFORT=
OPENAI_THINKING_ENABLED=

# ─── 通用 ───
HYBRID_PORT=3006
INFERENCE_PORT=3001
MAX_TOKENS=64000
COMPLETION_TIMEOUT_MS=12000
SYSTEM_PROMPT_OVERRIDE=
SYSTEM_PROMPT_PATH=

# 由扩展注入，一般无需手动填写
# PROXY_DEVICE_ID=
# PROXY_CLIENT_VERSION=

# ─── Prompt Cache / Token 优化 ───
# 总开关（默认 true）：关闭后以下 cache 相关优化全部停用
# PROMPT_CACHE_ENABLED=true
# Anthropic cache_control 打标（默认 true；网关不支持时会自动降级重试）
# ANTHROPIC_PROMPT_CACHE=true
# OpenAI 前缀缓存模式：observe（默认，仅稳定前缀+观测）/ auto / off
# OPENAI_PROMPT_CACHE=observe
# tools 按 name 稳定排序以稳定请求前缀（默认 true）
# PROMPT_CACHE_SORT_TOOLS=true
# cache 断点距消息尾部的偏移条数（默认 2）
# PROMPT_CACHE_TAIL_MESSAGES=2
# 在 system prompt 末尾追加当前 backend 信息（默认 false；开启会破坏前缀缓存）
# EXPOSE_BACKEND_INFO=false

# ─── 上游代理地址覆盖 ───
# 自定义 hybrid-server 上游 API 地址（默认 server.self-serve.windsurf.com）
# PROXY_API_HOST=
# 自定义 inference-proxy 上游地址（默认 inference.codeium.com）
# PROXY_INFERENCE_HOST=

# ─── 可选（高级）───
# ADMIN_TOKEN=
# PROXY_SESSION_SECRET=
# OPENAI_ENABLE_REASONING=false
# GATEWAY_CAPABILITY_TTL_MS=3600000
# STRIP_UNSIGNED_THINKING=false
# ALLOW_UNAUTH_CONFIG_POST=true
# VOYAGE_API_KEY=
